# Service
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Router model on the 1080 box
ROUTER_OLLAMA_BASE_URL=http://127.0.0.1:11434
ROUTER_MODEL=qwen3:8b-q4_K_M
ROUTER_NUM_CTX=4096
ROUTER_TEMPERATURE=0.0
ROUTER_TIMEOUT_SECONDS=1800

# Local coding backend on the 3080 10GB box
CODER_OLLAMA_BASE_URL=http://127.0.0.1:11435
CODER_MODEL=qwen3-coder:30b-a3b-q4_K_M
CODER_NUM_CTX=12000
CODER_TEMPERATURE=0.1
CODER_TIMEOUT_SECONDS=1800

# Local reasoning backend on the 3080 8GB box
REASONER_OLLAMA_BASE_URL=http://127.0.0.1:11436
REASONER_MODEL=qwen3:14b
REASONER_NUM_CTX=12000
REASONER_TEMPERATURE=0.1
REASONER_TIMEOUT_SECONDS=1800

OLLAMA_CONNECT_TIMEOUT_SECONDS=5
OLLAMA_POOL_CONNECTIONS=8
OLLAMA_POOL_MAXSIZE=16

# Optional Codex CLI backend (experimental, disabled by default)
ENABLE_CODEX_CLI=false
CODEX_CMD=codex
CODEX_WORKDIR=.
CODEX_TIMEOUT_SECONDS=1800

# Routing policy controls
ENABLE_LOCAL_CODER=true
ENABLE_LOCAL_REASONER=true
ENABLE_CODEX_CLI_BACKEND=false
DEFAULT_CLOUD_BACKEND=codex_cli
FAIL_OPEN=false

# Compaction transport logging
LOG_COMPACTION_PAYLOADS=false
COMPACTOR_RESPONSE_HEADROOM_TOKENS=3072
CODEX_SPARK_MODEL=gpt-5.3-codex-spark
CODEX_SPARK_QUALIFIED_RATE=0.2

# Test client
TEST_SERVER_BASE_URL=http://127.0.0.1:8080
